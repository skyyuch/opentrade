# OpenTrade — Root environment variables example
#
# Copy this file to `.env` (which is gitignored) for local development.
# Production secrets live in AWS Secrets Manager, NEVER here.
#
# Per cursor rule 50 (security):
#   - NEXT_PUBLIC_* values get bundled into the client; never put secrets there.
#   - Anything else is backend-only.
#   - All env vars are validated with zod at startup (packages/db, apps/api).

# ==============================================================================
# Database (packages/db, apps/api)
# ==============================================================================
# Local docker-compose default — see docker-compose.yml.
# Format: postgresql://{user}:{password}@{host}:{port}/{database}?schema=public
DATABASE_URL="postgresql://opentrade:opentrade_dev_password@localhost:5432/opentrade_dev?schema=public"

# Read replica connection string. In production this points at the RDS read replica;
# locally we just point at the same DB so the code path can be exercised end-to-end.
DATABASE_READ_URL="postgresql://opentrade:opentrade_dev_password@localhost:5432/opentrade_dev?schema=public"

# Prisma shadow database — only needed if you ever switch off `migrate dev` defaults.
# Leave commented unless Prisma complains.
# SHADOW_DATABASE_URL="postgresql://opentrade:opentrade_dev_password@localhost:5432/opentrade_shadow?schema=public"

# ==============================================================================
# API server (apps/api) — added in Commit number-five
# ==============================================================================
# Where Hono binds. Defaults to 0.0.0.0:4000 in local dev so a curl from the
# host or another container both work; production gets these from ECS task def.
SERVER_HOST="0.0.0.0"
SERVER_PORT="4000"

# Comma-separated whitelist of allowed CORS origins. Per rule 30 we never use
# wildcard. Add new origins here when web/console come online.
CORS_ORIGIN="http://localhost:3000,http://localhost:3001"

# Pino log level: fatal | error | warn | info | debug | trace
LOG_LEVEL="info"

# JWT signing secret (HS-style placeholder for Phase 0). Per rule 50 we will
# move to ES256 with private key in AWS Secrets Manager in Commit number-six or
# beyond; until the auth flow lands this value is only validated for length so
# tests fail-fast if it shrinks below 32 chars in any environment.
JWT_SECRET="dev_only_change_me_at_least_thirty_two_chars_long"

# ==============================================================================
# Placeholders for future commits — do NOT fill in yet
# ==============================================================================
# Auth (Phase 1 auth flow):
#   PRIVY_APP_SECRET=
#   NEXT_PUBLIC_PRIVY_APP_ID=
#
# Chain (Phase 1+):
#   NEXT_PUBLIC_CHAIN_ID=84532                 # Base Sepolia
#   NEXT_PUBLIC_REVIEW_REGISTRY_ADDRESS=0x...
#
# Storage (Phase 1+):
#   PINATA_JWT=
#   AWS_S3_BUCKET=
#
# AI (Phase 1+):
#   DEEPL_API_KEY=
