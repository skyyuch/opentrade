# OpenTrade — Root environment variables example
#
# Copy this file to `.env` (which is gitignored) for local development.
# Production secrets live in AWS Secrets Manager, NEVER here.
#
# Per cursor rule 50 (security):
#   - NEXT_PUBLIC_* values get bundled into the client; never put secrets there.
#   - Anything else is backend-only.
#   - All env vars are validated with zod at startup (packages/db, apps/api).

# ==============================================================================
# Database (packages/db, apps/api)
# ==============================================================================
# Local docker-compose default — see docker-compose.yml.
# Format: postgresql://{user}:{password}@{host}:{port}/{database}?schema=public
DATABASE_URL="postgresql://opentrade:opentrade_dev_password@localhost:5432/opentrade_dev?schema=public"

# Read replica connection string. In production this points at the RDS read replica;
# locally we just point at the same DB so the code path can be exercised end-to-end.
DATABASE_READ_URL="postgresql://opentrade:opentrade_dev_password@localhost:5432/opentrade_dev?schema=public"

# Prisma shadow database — only needed if you ever switch off `migrate dev` defaults.
# Leave commented unless Prisma complains.
# SHADOW_DATABASE_URL="postgresql://opentrade:opentrade_dev_password@localhost:5432/opentrade_shadow?schema=public"

# ==============================================================================
# API server (apps/api) — added in Commit number-five
# ==============================================================================
# Where Hono binds. Defaults to 0.0.0.0:4000 in local dev so a curl from the
# host or another container both work; production gets these from ECS task def.
SERVER_HOST="0.0.0.0"
SERVER_PORT="4000"

# Comma-separated whitelist of allowed CORS origins. Per rule 30 we never use
# wildcard. Add new origins here when web/console come online.
CORS_ORIGIN="http://localhost:3000,http://localhost:3001"

# Pino log level: fatal | error | warn | info | debug | trace
LOG_LEVEL="info"

# ES256 JWT keys (per rule 50: must be ES256, not HS256).
# Generate with: openssl ecparam -genkey -name prime256v1 -noout | openssl pkcs8 -topk8 -nocrypt
# Production keys live in AWS Secrets Manager.
JWT_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
JWT_PUBLIC_KEY_PEM="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# Default tenant UUID for Phase 1 single-tenant mode (HK market).
DEFAULT_TENANT_ID="00000000-0000-0000-0000-000000000001"

# ==============================================================================
# Web app (apps/web) — added in Commit number-six
# ==============================================================================
# Browser-visible URL of the OpenTrade API. NEXT_PUBLIC_* values get inlined
# into the client bundle at build time (per Next.js convention + rule 50),
# so NEVER place secrets behind this prefix.
# Production uses https://api.opentrade.io / staging.api.opentrade.io etc.
NEXT_PUBLIC_API_URL="http://localhost:4000"

# ==============================================================================
# Auth — Privy (Phase 1 auth flow, per ADR-0005)
# ==============================================================================
# Create a Privy app at https://dashboard.privy.io — enable Google, Apple,
# Email, SMS login + Smart Wallets on Base Sepolia + Gas Sponsorship.
NEXT_PUBLIC_PRIVY_APP_ID=""
PRIVY_APP_ID=""
PRIVY_APP_SECRET=""
# Found in Privy Dashboard > App Settings > Verification Key
PRIVY_VERIFICATION_KEY=""

# ==============================================================================
# Chain (Phase 1+, per ADR-0001)
# ==============================================================================
# Base Sepolia = 84532, Base Mainnet = 8453
NEXT_PUBLIC_CHAIN_ID="84532"
# Filled after ReviewRegistry deploy (Block 3)
# NEXT_PUBLIC_REVIEW_REGISTRY_ADDRESS=0x...

# ==============================================================================
# IPFS — Pinata (Phase 1+, per ADR-0019 D1)
# ==============================================================================
# Create an API key at https://app.pinata.cloud/developers/api-keys
# The JWT is used server-side only to pin review JSON to public IPFS.
PINATA_JWT=""

# ==============================================================================
# Placeholders for future commits
# ==============================================================================
# Storage (Phase 1+):
#   AWS_S3_BUCKET=
#
# AI (Phase 1+):
#   DEEPL_API_KEY=
