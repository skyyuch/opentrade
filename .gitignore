# OpenTrade .gitignore
# 任何加入 monorepo 的新工具，必須在這裡補上對應 ignore 規則

# ==============================================================================
# Dependencies
# ==============================================================================
node_modules/
.pnp
.pnp.js
.pnpm-store/
.yarn/
.npm/

# ==============================================================================
# Build outputs
# ==============================================================================
dist/
build/
out/
.next/
.turbo/
.swc/
*.tsbuildinfo
storybook-static/

# Foundry / Solidity
cache/
broadcast/
artifacts/
typechain-types/

# ==============================================================================
# Testing & coverage
# ==============================================================================
coverage/
.nyc_output/
*.lcov
test-results/
playwright-report/
playwright/.cache/

# ==============================================================================
# Environment & secrets (CRITICAL)
# ==============================================================================
# Any .env file MUST NOT be committed.
.env
.env.*
!.env.example
!.env.*.example

# AWS credentials
.aws/
aws-exports.js

# Terraform
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example
.terraform/
# Per ADR-0018 + rule 81: `.terraform.lock.hcl` IS committed. The lock
# file pins exact provider versions and hashes per platform so CI's
# `terraform init -backend=false` (per ADR-0018 D7) and every developer's
# `terraform init` resolve to byte-identical providers. Use
# `terraform providers lock -platform=linux_amd64 -platform=darwin_arm64
# -platform=darwin_amd64` to (re)generate multi-platform hashes when
# bumping AWS provider version.
crash.log
crash.*.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json
# Per ADR-0017: never commit a saved plan file. Plan artefacts are
# environment-specific and contain inferred resource attributes that
# look like state. Re-plan locally instead of trusting an old tfplan.
tfplan
*.tfplan

# Private keys / wallets
*.pem
*.key
private-key*
keystore/
wallet.json

# ==============================================================================
# OS / IDE
# ==============================================================================
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# JetBrains
.idea/
*.iml

# VSCode (allow shared settings, ignore user-specific)
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.history/

# Cursor (keep rules and agents config, ignore user state)
.cursor/state/
.cursor/cache/

# ==============================================================================
# Logs
# ==============================================================================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
logs/

# ==============================================================================
# Misc
# ==============================================================================
*.tgz
*.tar.gz
.vercel/
.netlify/
.serverless/
.fleet/

# Local development overrides
docker-compose.override.yml
local.config.*
