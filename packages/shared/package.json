{
  "name": "@opentrade/shared",
  "version": "0.0.0",
  "private": true,
  "description": "Shared TypeScript types, enums, and utilities used across OpenTrade apps and packages.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "src",
    "README.md"
  ],
  "scripts": {
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "test:ci": "vitest run --coverage",
    "clean": "rm -rf .turbo dist node_modules/.cache"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.8",
    "typescript": "^6.0.3",
    "vite": "^7.3.5",
    "vitest": "^4.1.8",
    "vitest-mock-extended": "^3.1.1"
  }
}
