{
  "name": "@opentrade/ui",
  "version": "0.0.0",
  "private": true,
  "description": "OpenTrade design system: design tokens, primitive components (shadcn-based), compound business components, and Storybook.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./design-tokens": {
      "types": "./src/design-tokens/index.ts",
      "default": "./src/design-tokens/index.ts"
    },
    "./utils": {
      "types": "./src/utils/index.ts",
      "default": "./src/utils/index.ts"
    },
    "./primitives": {
      "types": "./src/primitives/index.ts",
      "default": "./src/primitives/index.ts"
    },
    "./compounds": {
      "types": "./src/compounds/index.ts",
      "default": "./src/compounds/index.ts"
    },
    "./tailwind-preset": {
      "types": "./tailwind.preset.ts",
      "default": "./tailwind.preset.ts"
    },
    "./styles/globals.css": "./src/styles/globals.css"
  },
  "files": [
    "src",
    "tailwind.preset.ts",
    "README.md"
  ],
  "scripts": {
    "dev": "storybook dev -p 6006 --no-open",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "test:ci": "vitest run --coverage",
    "clean": "rm -rf .turbo dist storybook-static node_modules/.cache"
  },
  "peerDependencies": {
    "react": "^18.3.0 || ^19.0.0",
    "react-dom": "^18.3.0 || ^19.0.0"
  },
  "dependencies": {
    "@opentrade/shared": "workspace:*",
    "@radix-ui/react-slot": "^1.1.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.469.0",
    "tailwind-merge": "^2.5.5"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^8.6.18",
    "@storybook/addon-essentials": "^8.6.18",
    "@storybook/addon-interactions": "^8.6.18",
    "@storybook/addon-themes": "^8.6.18",
    "@storybook/blocks": "^8.6.18",
    "@storybook/react": "^8.6.18",
    "@storybook/react-vite": "^8.6.18",
    "@storybook/test": "^8.6.18",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^3.2.4",
    "autoprefixer": "^10.4.20",
    "axe-core": "^4.10.3",
    "jsdom": "^26.1.0",
    "postcss": "^8.5.1",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "storybook": "^8.6.18",
    "tailwindcss": "^4.3.0",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.7.2",
    "vite": "^5.4.11",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^3.2.4"
  }
}
