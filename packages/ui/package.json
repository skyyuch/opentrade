{
  "name": "@opentrade/ui",
  "version": "0.0.0",
  "private": true,
  "description": "OpenTrade design system: design tokens, primitive components (shadcn-based), compound business components, and Storybook.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./design-tokens": {
      "types": "./src/design-tokens/index.ts",
      "default": "./src/design-tokens/index.ts"
    }
  },
  "files": [
    "src",
    "README.md"
  ],
  "scripts": {
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "echo 'no tests yet' && exit 0",
    "test:unit": "echo 'no tests yet' && exit 0",
    "storybook": "echo 'storybook not yet initialized — see Phase 0.4' && exit 0",
    "build-storybook": "echo 'storybook not yet initialized' && exit 0",
    "clean": "rm -rf .turbo dist storybook-static node_modules/.cache"
  },
  "dependencies": {
    "@opentrade/shared": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.7.2"
  }
}
