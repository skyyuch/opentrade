{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "rootDir": ".",
    "outDir": "./dist",
    "tsBuildInfoFile": "./node_modules/.cache/.tsbuildinfo",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "preserve"
  },
  "include": [
    "src/**/*",
    "tailwind.preset.ts",
    "tailwind.config.ts",
    ".storybook/**/*",
    "vitest.config.ts",
    "vitest.setup.ts"
  ],
  "exclude": ["node_modules", "dist", "storybook-static"],
  "references": [{ "path": "../shared" }]
}
