{
  "name": "@opentrade/db",
  "version": "0.0.0",
  "private": true,
  "description": "PostgreSQL schema and Prisma client. Imported only by apps/api; other packages may import types only.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "src",
    "prisma",
    "README.md"
  ],
  "scripts": {
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "echo 'no tests yet' && exit 0",
    "test:unit": "echo 'no tests yet' && exit 0",
    "clean": "rm -rf .turbo dist node_modules/.cache",
    "db:format": "prisma format",
    "db:generate": "prisma generate",
    "db:migrate:dev": "dotenv -e ../../.env -- prisma migrate dev",
    "db:migrate:deploy": "dotenv -e ../../.env -- prisma migrate deploy",
    "db:migrate:reset": "dotenv -e ../../.env -- prisma migrate reset",
    "db:migrate:status": "dotenv -e ../../.env -- prisma migrate status",
    "db:seed": "dotenv -e ../../.env -- tsx scripts/seed.ts",
    "fetch:sfc": "tsx scripts/fetch-sfc-brokers.ts",
    "sync:sfc": "dotenv -e ../../.env -- tsx scripts/sync-sfc-brokers.ts",
    "db:studio": "dotenv -e ../../.env -- prisma studio",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@opentrade/shared": "workspace:*",
    "@prisma/client": "^6.19.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "prisma": "^6.19.3",
    "tsx": "^4.22.1",
    "typescript": "^5.7.2"
  }
}
