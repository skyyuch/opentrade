{
  "name": "@opentrade/db",
  "version": "0.0.0",
  "private": true,
  "description": "PostgreSQL schema and Prisma client. Imported only by apps/api; other packages may import types only.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./sfc": {
      "types": "./src/sfc/index.ts",
      "default": "./src/sfc/index.ts"
    }
  },
  "files": [
    "src",
    "prisma",
    "README.md"
  ],
  "scripts": {
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "echo 'no tests yet' && exit 0",
    "test:unit": "echo 'no tests yet' && exit 0",
    "clean": "rm -rf .turbo dist node_modules/.cache",
    "db:format": "prisma format",
    "db:generate": "prisma generate",
    "db:migrate:dev": "dotenv -e ../../.env -- prisma migrate dev",
    "db:migrate:deploy": "dotenv -e ../../.env -- prisma migrate deploy",
    "db:migrate:reset": "dotenv -e ../../.env -- prisma migrate reset && pnpm db:seed",
    "db:migrate:status": "dotenv -e ../../.env -- prisma migrate status",
    "db:seed": "dotenv -e ../../.env -- tsx scripts/seed.ts",
    "db:backfill:zh-hans": "dotenv -e ../../.env -- tsx scripts/backfill-zh-hans.ts",
    "db:backfill:source-locale": "dotenv -e ../../.env -- tsx scripts/backfill-source-locale.ts",
    "db:backfill:sentiment": "dotenv -e ../../.env -- tsx scripts/backfill-sentiment.ts",
    "db:backfill:prod": "pnpm db:backfill:zh-hans && pnpm db:backfill:source-locale && pnpm db:backfill:sentiment",
    "fetch:sfc": "tsx scripts/fetch-sfc-brokers.ts",
    "fetch:cgse": "tsx scripts/fetch-cgse-members.ts",
    "fetch:sfc:details": "dotenv -e ../../.env -- tsx scripts/fetch-sfc-details.ts",
    "crawl:logos": "dotenv -e ../../.env -- tsx scripts/crawl-broker-logos.ts",
    "sync:sfc": "dotenv -e ../../.env -- tsx scripts/sync-sfc-brokers.ts",
    "sync:instruments": "dotenv -e ../../.env -- tsx scripts/sync-instruments.ts",
    "db:studio": "dotenv -e ../../.env -- prisma studio",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@opentrade/shared": "workspace:*",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "opencc-js": "^1.3.1",
    "pg": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1061.0",
    "@types/pg": "^8.20.0",
    "cheerio": "^1.2.0",
    "dotenv": "^17.4.2",
    "dotenv-cli": "^11.0.0",
    "fflate": "^0.8.3",
    "prisma": "^7.8.0",
    "sharp": "^0.34.5",
    "tsx": "^4.22.3",
    "typescript": "^5.7.2"
  }
}
