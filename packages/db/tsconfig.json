{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "rootDir": ".",
    "outDir": "./dist",
    "tsBuildInfoFile": "./node_modules/.cache/.tsbuildinfo"
  },
  "include": ["src/**/*", "scripts/**/*", "prisma.config.ts"],
  "exclude": ["node_modules", "dist", "prisma/migrations", "**/*.test.ts", "**/*.spec.ts"],
  "references": [{ "path": "../shared" }]
}
