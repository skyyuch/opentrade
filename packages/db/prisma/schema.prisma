// OpenTrade — Prisma schema (single source of truth)
//
// This schema models the **off-chain mirror** of OpenTrade. It deliberately
// stays small in Phase 0 (Tenant / User / Broker / BrokerLicense) and grows
// per-domain in later phases (Review / KolSignal / Dispute / OutboxEvent / ...).
//
// Authoritative rules:
//   - .cursor/rules/31-database-prisma.mdc
//   - ADR-0002 (AWS RDS Postgres 16)
//   - ADR-0006 (DDD + Modular Monolith — only apps/api consumes the runtime client)
//   - ADR-0012 (local docker-compose Postgres for dev)
//
// Style conventions:
//   - Model:    PascalCase singular (Tenant, BrokerLicense)
//   - Field:    camelCase
//   - Table:    snake_case via @@map
//   - IDs:      UUID v4 stored as @db.Uuid
//   - Auditing: createdAt + updatedAt on every row; deletedAt for soft delete
//   - Tenant:   every user-scoped row carries tenantId so a future Prisma
//               extension can transparently inject the filter

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// Enums
// =============================================================================

/// Application role assigned to a User. Distinct from on-chain SBT tier:
/// `role` controls platform permissions, `sbtTier` reflects on-chain identity.
enum UserRole {
  USER // Default. Anyone signed in via Privy.
  REVIEWER // Has the right to submit on-chain reviews (paired with L2 SBT).
  JURY // Founding juror; eligible for dispute arbitration.
  ADMIN // Internal staff (multisig-controlled in prod).
}

/// On-chain identity tier — mirrors docs/01-architecture.md §6 "身份分層".
/// L0 (visitor) is not represented in the DB; users always have at least L1
/// once they have completed a Privy social login.
enum SbtTier {
  L1 // Logged-in via Privy.
  L2 // Verified investor (zk-proof of broker statement).
  L3 // Founding juror (invite-only SBT).
  L4 // Institution (KYC + license verified).
}

/// Regulator that issued a broker license. V1 ships HK_SFC only; future
/// regulators (SG_MAS, TW_FSC, JP_FSA, ...) can be added as non-breaking
/// enum values. Naming uses an ISO-country prefix to avoid name collisions.
enum Regulator {
  HK_SFC
}

/// Specific license category. Naming convention is `<REGULATOR>_<CATEGORY>`,
/// so each value is self-describing about which jurisdiction's framework it
/// belongs to and can be displayed as-is in admin tools.
///
/// SFC categories map to Hong Kong's 10 "regulated activities":
///   https://www.sfc.hk/en/Welcome-to-the-Fintech-Contact-Point/Types-of-regulated-activities
enum LicenseType {
  HK_SFC_TYPE_1 // Dealing in securities — 證券交易
  HK_SFC_TYPE_2 // Dealing in futures contracts — 期貨合約交易
  HK_SFC_TYPE_3 // Leveraged foreign exchange trading — 槓桿式外匯交易
  HK_SFC_TYPE_4 // Advising on securities — 就證券提供意見
  HK_SFC_TYPE_5 // Advising on futures contracts — 就期貨合約提供意見
  HK_SFC_TYPE_6 // Advising on corporate finance — 就機構融資提供意見
  HK_SFC_TYPE_7 // Providing automated trading services — 提供自動化交易服務
  HK_SFC_TYPE_8 // Securities margin financing — 證券保證金融資
  HK_SFC_TYPE_9 // Asset management — 提供資產管理
  HK_SFC_TYPE_10 // Providing credit rating services — 提供信貸評級服務
}

/// Lifecycle of a single broker license. Per project red-line rules we NEVER
/// hard-delete: a revoked license is kept with status = REVOKED so it remains
/// publicly visible on the broker profile.
enum LicenseStatus {
  ACTIVE
  SUSPENDED
  REVOKED
  EXPIRED
}

// =============================================================================
// Models
// =============================================================================

/// A logical jurisdiction / market segment. V1 only ships `code = "hk"`; the
/// tenantId column on every user-scoped table exists from day one so future
/// regions (TW, SG, ...) can be added without schema migrations.
model Tenant {
  id            String   @id @default(uuid()) @db.Uuid
  code          String   @unique
  name          String
  defaultLocale String   @default("zh-Hant")
  timezone      String   @default("Asia/Hong_Kong")
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  users                   User[]
  brokers                 Broker[]
  licenses                BrokerLicense[]
  reviews                 Review[]
  outboxEvents            OutboxEvent[]
  sbtVerificationRequests SbtVerificationRequest[]
  brokerClaimRequests     BrokerClaimRequest[]
  userVerifiedBrokers     UserVerifiedBroker[]

  @@map("tenants")
}

/// A registered platform user. Identity originates from Privy social login;
/// the AA wallet address is populated asynchronously after Privy mints it.
///
/// PII handling (per rule 50):
///   - `email` is a plaintext placeholder in Phase 0. App-layer envelope
///     encryption + display-time masking lands with the auth flow in Commit #5.
///   - `displayName` is user-controlled and not treated as PII.
///   - `privyId` is an opaque external identifier; not PII on its own.
model User {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @db.Uuid
  privyId         String
  walletAddress   String?  @unique
  email           String?
  displayName     String?
  preferredLocale String?
  role            UserRole @default(USER)
  sbtTier         SbtTier  @default(L1)
  sbtTokenId      Int?
  sbtMintTxHash   String?
  username        String?  @unique
  passwordHash    String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tenant                  Tenant                   @relation(fields: [tenantId], references: [id])
  reviews                 Review[]
  sbtVerificationRequests SbtVerificationRequest[]
  verifiedBrokers         UserVerifiedBroker[]

  @@unique([tenantId, privyId])
  @@index([tenantId, role])
  @@index([tenantId, sbtTier])
  @@map("users")
}

/// A financial services provider that can receive reviews. For Phase 1 these
/// are Hong Kong SFC-licensed securities brokers, seeded from public SFC data
/// so users can write reviews about brokers that have not yet onboarded.
///
/// `isClaimed` flips to true once an L4 KYC has completed for a custodial
/// staff user. Pre-claim, `description` / `logoUrl` come from the seed.
///
/// SFC detail fields (`addressEn`, `addressZh`, `sfcDetailJson`) are
/// populated by the offline SFC detail fetcher and contain public-register
/// data such as responsible officers, conditions, and disciplinary actions.
model Broker {
  id                String    @id @default(uuid()) @db.Uuid
  tenantId          String    @db.Uuid
  slug              String
  legalName         String
  displayName       String
  // Simplified Chinese display name, derived from `displayName` via OpenCC
  // `t2s.json` (Traditional → Simplified). Nullable for two reasons:
  //   1. Backfill is best-effort — OpenCC may decline a small fraction of
  //      rows (rare unicode codepoints), and we don't want to block
  //      migrations on those edge cases.
  //   2. Admins may want to override OpenCC output for individual brokers
  //      where the auto-conversion is technically valid but semantically
  //      awkward (e.g. specific 香港繁體 idioms). Nullable lets the helper
  //      fall back to `displayName` rather than persisting a "wrong" value.
  // Per ADR-0026; see also cursor rule 51 §模式 A.
  displayNameZhHans String?
  ceNumber          String?
  websiteUrl        String?
  description       String?   @db.Text
  logoUrl           String?
  addressEn         String?   @db.Text
  addressZh         String?   @db.Text
  sfcDetailJson     Json?
  isClaimed         Boolean   @default(false)
  claimedAt         DateTime?
  claimedByUserId   String?   @db.Uuid

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tenant        Tenant               @relation(fields: [tenantId], references: [id])
  licenses      BrokerLicense[]
  reviews       Review[]
  claimRequests BrokerClaimRequest[]

  @@unique([tenantId, slug])
  @@index([tenantId, isClaimed])
  @@index([tenantId, legalName])
  @@index([ceNumber])
  @@map("brokers")
}

/// A single regulator-issued license belonging to a Broker. Normalized into
/// its own table so we can track issuance date, expiry, and lifecycle status
/// without losing history. On revocation we DO NOT delete the row; we change
/// status to REVOKED and keep showing the historical record on the broker
/// profile (this is a core trust signal — investors must see who got struck off).
model BrokerLicense {
  id            String        @id @default(uuid()) @db.Uuid
  tenantId      String        @db.Uuid
  brokerId      String        @db.Uuid
  regulator     Regulator
  licenseType   LicenseType
  licenseNumber String
  issuedAt      DateTime
  expiresAt     DateTime?
  status        LicenseStatus @default(ACTIVE)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id])
  broker Broker @relation(fields: [brokerId], references: [id])

  @@unique([tenantId, regulator, licenseNumber])
  @@index([tenantId, brokerId])
  @@index([tenantId, status])
  @@index([tenantId, regulator, licenseType])
  @@map("broker_licenses")
}

/// Status of a claim or verification request.
enum ClaimStatus {
  PENDING
  APPROVED
  REJECTED
}

/// Status of an SBT verification request (L2 identity proof).
enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

/// A request from a user to verify their broker account for L2 SBT.
/// Per ADR-0022: the server never receives raw account data. Instead it
/// stores a commitment hash computed client-side and an encrypted evidence
/// IPFS CID that only an admin can decrypt.
model SbtVerificationRequest {
  id               String             @id @default(uuid()) @db.Uuid
  tenantId         String             @db.Uuid
  userId           String             @db.Uuid
  brokerSlug       String
  commitment       String
  evidenceIpfsCid  String
  evidenceMimeType String?
  status           VerificationStatus @default(PENDING)
  adminNote        String?            @db.Text
  createdAt        DateTime           @default(now())
  reviewedAt       DateTime?

  user               User                @relation(fields: [userId], references: [id])
  tenant             Tenant              @relation(fields: [tenantId], references: [id])
  verifiedBrokerLink UserVerifiedBroker?

  @@index([tenantId, status])
  @@index([tenantId, userId])
  @@map("sbt_verification_requests")
}

/// Append-only record of brokers a user has been verified for. Inserted in
/// the same transaction as the verification approval, with a unique
/// (userId, brokerSlug) constraint. Per ADR-0025 (Phase 1) this list is
/// off-chain — Phase 2 batches these rows into the on-chain ReviewerSBT v2
/// broker mapping. Each row's `commitment` mirrors the original verification
/// request and is also emitted as an outbox event with a hash chain
/// pointing to the user's previous broker, giving auditors a way to detect
/// post-hoc admin tampering until the data lands on-chain.
model UserVerifiedBroker {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @db.Uuid
  userId         String   @db.Uuid
  brokerSlug     String
  verificationId String   @unique @db.Uuid
  commitment     String
  approvedAt     DateTime @default(now())

  user         User                   @relation(fields: [userId], references: [id])
  tenant       Tenant                 @relation(fields: [tenantId], references: [id])
  verification SbtVerificationRequest @relation(fields: [verificationId], references: [id])

  @@unique([userId, brokerSlug])
  @@index([tenantId, userId])
  @@index([tenantId, brokerSlug])
  @@map("user_verified_brokers")
}

/// A request from a merchant to claim ownership of a broker profile.
/// Manual KYC: user provides CE ref number and a company authorization letter
/// (uploaded to IPFS). Admin reviews and approves/rejects.
model BrokerClaimRequest {
  id                   String      @id @default(uuid()) @db.Uuid
  tenantId             String      @db.Uuid
  brokerId             String      @db.Uuid
  userId               String      @db.Uuid
  ceRefNumber          String
  companyLetterIpfsCid String
  status               ClaimStatus @default(PENDING)
  adminNote            String?     @db.Text
  createdAt            DateTime    @default(now())
  reviewedAt           DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id])
  broker Broker @relation(fields: [brokerId], references: [id])

  @@index([tenantId, status])
  @@index([tenantId, brokerId])
  @@map("broker_claim_requests")
}

/// Lifecycle status of a review as it moves through the submission pipeline.
/// Reviews start PENDING while IPFS pinning + chain tx are in flight, then
/// transition to CONFIRMED once the chain tx receipt is verified. FAILED marks
/// a permanently broken submission (IPFS or chain failure after max retries).
enum ReviewStatus {
  PENDING // Created in DB; IPFS pin + chain tx not yet confirmed.
  CONFIRMED // On-chain tx confirmed; review is immutable.
  FAILED // Pipeline permanently failed (operator intervention needed).
}

/// Three-way sentiment replacing the legacy 1-5 star `rating` column per
/// ADR-0028. The values map to the project's red-line goal of removing
/// paid-promotion-gameable surfaces (rule 00) while preserving an at-a-glance
/// trust signal that pairs with `verifiedComplaintCount` (per ADR-0029).
///
/// Rendered as `讚 / 普通 / 不讚` in zh-Hant per the 2026-05-25 meeting C1
/// resolution; the API uses these enum names verbatim and the UI handles the
/// localisation.
enum Sentiment {
  POSITIVE
  NEUTRAL
  NEGATIVE
}

/// An off-chain mirror of a single review submission. The authoritative copy
/// of the content lives on IPFS (addressed by `ipfsCid`), and its tamper-proof
/// anchor lives on-chain in ReviewRegistry (addressed by `chainReviewId` +
/// `txHash`). This DB row exists for fast query and full-text search; it is
/// NOT the source of truth for immutability — the chain is.
///
/// Per ADR-0019 D1: contentHash = keccak256 of the IPFS JSON; the contract
/// stores (contentHash, ipfsCid) and this table mirrors those values so the
/// API can serve reviews without querying the chain on every page load.
///
/// Per ADR-0019 D5 + project red line: there is NO deleteReview endpoint.
/// Soft-delete (`deletedAt`) is reserved for extraordinary legal compliance
/// (court order) and requires an ADR + admin audit log.
model Review {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @db.Uuid
  userId   String @db.Uuid
  brokerId String @db.Uuid

  /// keccak256(JSON.stringify(ipfsPayload)) — matches on-chain contentHash.
  contentHash   String
  /// IPFS CID where the full review JSON is pinned (via Pinata).
  ipfsCid       String?
  /// On-chain review ID returned by ReviewRegistry.submitReview().
  chainReviewId Int?
  /// Transaction hash of the on-chain submission.
  txHash        String?

  title     String     @db.VarChar(200)
  body      String     @db.Text
  /// 1-5 star rating.
  rating    Int        @db.SmallInt
  /// Three-way sentiment per ADR-0028. Nullable during the M3 transition
  /// window — legacy rows are backfilled by `db:backfill:sentiment` (M3.2)
  /// and the column becomes required at submit time in M4 (ADR-0028 D4).
  sentiment Sentiment?

  status       ReviewStatus @default(PENDING)
  sourceLocale String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tenant       Tenant              @relation(fields: [tenantId], references: [id])
  user         User                @relation(fields: [userId], references: [id])
  broker       Broker              @relation(fields: [brokerId], references: [id])
  translations ReviewTranslation[]

  @@index([tenantId, brokerId, createdAt])
  @@index([tenantId, userId])
  @@index([tenantId, status])
  // Powers the `SentimentDistribution` aggregate on the broker detail page
  // (per ADR-0028 D1 + D7); the (tenantId, brokerId) prefix matches every
  // sentiment-grouped query against a single broker.
  @@index([tenantId, brokerId, sentiment])
  @@map("reviews")
}

/// Machine-translated version of a review in a specific locale.
/// Per ADR-0023: translations are additive siblings of the original
/// Review content, stored per locale for instant serving.
model ReviewTranslation {
  id           String   @id @default(uuid()) @db.Uuid
  reviewId     String   @db.Uuid
  locale       String
  title        String   @db.VarChar(200)
  body         String   @db.Text
  translatedAt DateTime @default(now())

  review Review @relation(fields: [reviewId], references: [id])

  @@unique([reviewId, locale])
  @@map("review_translations")
}

/// Transactional outbox for cross-domain domain events (per ADR-0006 outbox
/// pattern). Use cases write business rows + an OutboxEvent in the same DB
/// transaction; a background worker (added in Phase 1) reads pending rows
/// and republishes them to SQS. This guarantees we never "commit the write
/// but lose the event" — the two are atomic at the database level.
///
/// Lifecycle:
///   - `processedAt = null`           → pending; worker will pick it up.
///   - `processedAt != null`          → delivered to downstream.
///   - `attempts` / `lastError`       → retry diagnostics for the worker.
///
/// Retention: per rule 31, processed rows older than 7 days MAY be hard
/// deleted by a cron job (this is the one exception to "never DELETE" rule).
///
/// Field shape:
///   - `aggregateType` — namespaced string identifying the producing
///                       aggregate (e.g. `"review"`, `"kol_signal"`).
///   - `aggregateId`   — UUID of that aggregate, stored as string to keep
///                       this table aggregate-agnostic (no FK).
///   - `eventType`     — dotted event name (e.g. `"review.submitted"`,
///                       `"kol_signal.created"`); the worker uses this to
///                       route to the correct SQS topic / subscriber.
///   - `payload`       — JSON serialisable payload; must NOT contain PII
///                       (per rule 50). Use IDs and hashes, not raw values.
model OutboxEvent {
  id            String    @id @default(uuid()) @db.Uuid
  tenantId      String    @db.Uuid
  aggregateType String
  aggregateId   String    @db.Uuid
  eventType     String
  payload       Json
  attempts      Int       @default(0)
  lastError     String?   @db.Text
  createdAt     DateTime  @default(now())
  processedAt   DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id])

  // Worker query: "fetch oldest unprocessed events". The partial-index shape
  // (processedAt first, createdAt second) lets Postgres skip processed rows
  // efficiently even before the 7-day GC kicks in.
  @@index([processedAt, createdAt])
  // Tenant-scoped pending lookup; mirrors every other table's tenant index.
  @@index([tenantId, processedAt])
  // Forensic lookup: "what events did aggregate X emit?" — used by admin
  // tooling and by reprocessing scripts after a downstream outage.
  @@index([tenantId, aggregateType, aggregateId])
  @@map("outbox_events")
}
