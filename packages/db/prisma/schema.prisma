// OpenTrade — Prisma schema (single source of truth)
//
// This schema models the **off-chain mirror** of OpenTrade. It deliberately
// stays small in Phase 0 (Tenant / User / Broker / BrokerLicense) and grows
// per-domain in later phases (Review / KolSignal / Dispute / OutboxEvent / ...).
//
// Authoritative rules:
//   - .cursor/rules/31-database-prisma.mdc
//   - ADR-0002 (AWS RDS Postgres 16)
//   - ADR-0006 (DDD + Modular Monolith — only apps/api consumes the runtime client)
//   - ADR-0012 (local docker-compose Postgres for dev)
//
// Style conventions:
//   - Model:    PascalCase singular (Tenant, BrokerLicense)
//   - Field:    camelCase
//   - Table:    snake_case via @@map
//   - IDs:      UUID v4 stored as @db.Uuid
//   - Auditing: createdAt + updatedAt on every row; deletedAt for soft delete
//   - Tenant:   every user-scoped row carries tenantId so a future Prisma
//               extension can transparently inject the filter

generator client {
  // Prisma 7 Rust-free client (ADR-0041, supersedes ADR-0013).
  // `output` is mandatory on the `prisma-client` provider; the generated
  // client is git-ignored and (re)built via `prisma generate` (postinstall + CI).
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  // Prisma 7: connection URLs live in prisma.config.ts (CLI) and the driver
  // adapter in src/client.ts (runtime); `url` is no longer set here.
  provider = "postgresql"
}

// =============================================================================
// Enums
// =============================================================================

/// Application role assigned to a User. Distinct from on-chain SBT tier:
/// `role` controls platform permissions, `sbtTier` reflects on-chain identity.
enum UserRole {
  USER // Default. Anyone signed in via Privy.
  REVIEWER // Has the right to submit on-chain reviews (paired with L2 SBT).
  JURY // Founding juror; eligible for dispute arbitration.
  ADMIN // Internal staff (multisig-controlled in prod).
}

/// On-chain identity tier — mirrors docs/01-architecture.md §6 "身份分層".
/// L0 (visitor) is not represented in the DB; users always have at least L1
/// once they have completed a Privy social login.
enum SbtTier {
  L1 // Logged-in via Privy.
  L2 // Verified investor (zk-proof of broker statement).
  L3 // Founding juror (invite-only SBT).
  L4 // Institution (KYC + license verified).
}

/// Category of reviewable financial-service provider modelled by `Broker`.
/// Per ADR-0045 a bullion dealer is NOT a new domain — it is a `Broker` row
/// with a different category, registry source, and license vocabulary. The
/// discriminator keeps the entire reviews / complaints / claim / verify /
/// on-chain pipeline unchanged (they all bind to `brokerId`). New verticals
/// (e.g. INSURANCE, MPF) can be added here as non-breaking enum values.
enum BrokerCategory {
  SECURITIES // SFC-licensed securities broker (existing behaviour).
  BULLION // HKGX-member bullion / precious-metals dealer (per ADR-0045 / ADR-0050).
}

/// Regulator (or self-regulatory body) that issued a broker license. V1 ships
/// HK_SFC; HK_HKGX is the Hong Kong Gold Exchange (香港黃金交易所) — the
/// corporatised successor to the Chinese Gold & Silver Exchange Society
/// (金銀業貿易場 / CGSE) since 2025-01-01 — a self-regulatory bullion exchange
/// whose member roster is the authoritative source for bullion dealers (per
/// ADR-0045, rebranded per ADR-0050). Future regulators (SG_MAS, TW_FSC,
/// JP_FSA, ...) can be added as non-breaking enum values. Naming uses an
/// ISO-country prefix to avoid name collisions.
enum Regulator {
  HK_SFC
  HK_HKGX // Hong Kong Gold Exchange (香港黃金交易所) — formerly CGSE, per ADR-0050.
}

/// Specific license category. Naming convention is `<REGULATOR>_<CATEGORY>`,
/// so each value is self-describing about which jurisdiction's framework it
/// belongs to and can be displayed as-is in admin tools.
///
/// SFC categories map to Hong Kong's 10 "regulated activities":
///   https://www.sfc.hk/en/Welcome-to-the-Fintech-Contact-Point/Types-of-regulated-activities
enum LicenseType {
  HK_SFC_TYPE_1 // Dealing in securities — 證券交易
  HK_SFC_TYPE_2 // Dealing in futures contracts — 期貨合約交易
  HK_SFC_TYPE_3 // Leveraged foreign exchange trading — 槓桿式外匯交易
  HK_SFC_TYPE_4 // Advising on securities — 就證券提供意見
  HK_SFC_TYPE_5 // Advising on futures contracts — 就期貨合約提供意見
  HK_SFC_TYPE_6 // Advising on corporate finance — 就機構融資提供意見
  HK_SFC_TYPE_7 // Providing automated trading services — 提供自動化交易服務
  HK_SFC_TYPE_8 // Securities margin financing — 證券保證金融資
  HK_SFC_TYPE_9 // Asset management — 提供資產管理
  HK_SFC_TYPE_10 // Providing credit rating services — 提供信貸評級服務

  // HKGX membership is a single status (not 10 regulated-activity categories
  // like SFC), so one value suffices; the 行員編號 member code (e.g. 001, 009)
  // is stored in BrokerLicense.licenseNumber. Per ADR-0045 D3 / ADR-0050.
  HK_HKGX_MEMBER // HKGX membership — 香港黃金交易所行員
}

/// Lifecycle of a single broker license. Per project red-line rules we NEVER
/// hard-delete: a revoked license is kept with status = REVOKED so it remains
/// publicly visible on the broker profile.
enum LicenseStatus {
  ACTIVE
  SUSPENDED
  REVOKED
  EXPIRED
}

// =============================================================================
// Models
// =============================================================================

/// A logical jurisdiction / market segment. V1 only ships `code = "hk"`; the
/// tenantId column on every user-scoped table exists from day one so future
/// regions (TW, SG, ...) can be added without schema migrations.
model Tenant {
  id            String   @id @default(uuid()) @db.Uuid
  code          String   @unique
  name          String
  defaultLocale String   @default("zh-Hant")
  timezone      String   @default("Asia/Hong_Kong")
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  users                   User[]
  brokers                 Broker[]
  licenses                BrokerLicense[]
  reviews                 Review[]
  outboxEvents            OutboxEvent[]
  sbtVerificationRequests SbtVerificationRequest[]
  brokerClaimRequests     BrokerClaimRequest[]
  userVerifiedBrokers     UserVerifiedBroker[]
  kols                    Kol[]
  signals                 Signal[]
  notifications           Notification[]
  kolNotes                KolNote[]
  moderationTerms         ModerationTerm[]
  moderationTermAudits    ModerationTermAudit[]

  @@map("tenants")
}

/// A registered platform user. Identity originates from Privy social login;
/// the AA wallet address is populated asynchronously after Privy mints it.
///
/// PII handling (per rule 50):
///   - `email` is a plaintext placeholder in Phase 0. App-layer envelope
///     encryption + display-time masking lands with the auth flow in Commit #5.
///   - `displayName` is user-controlled and not treated as PII.
///   - `privyId` is an opaque external identifier; not PII on its own.
model User {
  id                String   @id @default(uuid()) @db.Uuid
  tenantId          String   @db.Uuid
  privyId           String
  walletAddress     String?  @unique
  email             String?
  displayName       String?
  preferredLocale   String?
  role              UserRole @default(USER)
  sbtTier           SbtTier  @default(L1)
  sbtTokenId        Int?
  sbtMintTxHash     String?
  username          String?  @unique
  passwordHash      String?
  notificationPrefs Json?
  privacyPrefs      Json?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tenant                  Tenant                   @relation(fields: [tenantId], references: [id])
  reviews                 Review[]
  sbtVerificationRequests SbtVerificationRequest[]
  verifiedBrokers         UserVerifiedBroker[]
  kolProfiles             Kol[]
  kolFollows              KolFollow[]
  notifications           Notification[]

  @@unique([tenantId, privyId])
  @@index([tenantId, role])
  @@index([tenantId, sbtTier])
  @@map("users")
}

/// A reviewable, registered financial-service provider. Originally Hong Kong
/// SFC-licensed securities brokers (seeded from public SFC data), the meaning
/// is widened by `category` to cover other verticals — currently HKGX-member
/// bullion dealers (per ADR-0045 D4 / ADR-0050). The model is intentionally NOT renamed
/// to `Provider`; revisit only if a third non-broker category proves the name
/// is a real problem.
///
/// `isClaimed` flips to true once an L4 KYC has completed for a custodial
/// staff user. Pre-claim, `description` / `logoUrl` come from the seed.
///
/// SFC detail fields (`addressEn`, `addressZh`, `sfcDetailJson`) are
/// populated by the offline SFC detail fetcher and contain public-register
/// data such as responsible officers, conditions, and disciplinary actions.
/// They are null on non-SECURITIES rows (e.g. bullion dealers) — the same
/// nullability trade-off ADR-0029 accepted for its discriminator.
model Broker {
  id                String         @id @default(uuid()) @db.Uuid
  tenantId          String         @db.Uuid
  // Discriminator widening Broker to multiple verticals (per ADR-0045).
  // @default(SECURITIES) means every existing row inherits the correct
  // category with zero backfill.
  category          BrokerCategory @default(SECURITIES)
  slug              String
  legalName         String
  displayName       String
  // Simplified Chinese display name, derived from `displayName` via OpenCC
  // `t2s.json` (Traditional → Simplified). Nullable for two reasons:
  //   1. Backfill is best-effort — OpenCC may decline a small fraction of
  //      rows (rare unicode codepoints), and we don't want to block
  //      migrations on those edge cases.
  //   2. Admins may want to override OpenCC output for individual brokers
  //      where the auto-conversion is technically valid but semantically
  //      awkward (e.g. specific 香港繁體 idioms). Nullable lets the helper
  //      fall back to `displayName` rather than persisting a "wrong" value.
  // Per ADR-0026; see also cursor rule 51 §模式 A.
  displayNameZhHans String?
  ceNumber          String?
  websiteUrl        String?
  description       String?        @db.Text
  logoUrl           String?
  addressEn         String?        @db.Text
  addressZh         String?        @db.Text
  sfcDetailJson     Json?
  isClaimed         Boolean        @default(false)
  claimedAt         DateTime?
  claimedByUserId   String?        @db.Uuid

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tenant        Tenant               @relation(fields: [tenantId], references: [id])
  licenses      BrokerLicense[]
  reviews       Review[]
  claimRequests BrokerClaimRequest[]

  @@unique([tenantId, slug])
  @@index([tenantId, isClaimed])
  @@index([tenantId, legalName])
  @@index([tenantId, category])
  @@index([ceNumber])
  @@map("brokers")
}

/// A single regulator-issued license belonging to a Broker. Normalized into
/// its own table so we can track issuance date, expiry, and lifecycle status
/// without losing history. On revocation we DO NOT delete the row; we change
/// status to REVOKED and keep showing the historical record on the broker
/// profile (this is a core trust signal — investors must see who got struck off).
model BrokerLicense {
  id            String        @id @default(uuid()) @db.Uuid
  tenantId      String        @db.Uuid
  brokerId      String        @db.Uuid
  regulator     Regulator
  licenseType   LicenseType
  licenseNumber String
  issuedAt      DateTime
  expiresAt     DateTime?
  status        LicenseStatus @default(ACTIVE)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id])
  broker Broker @relation(fields: [brokerId], references: [id])

  @@unique([tenantId, regulator, licenseNumber])
  @@index([tenantId, brokerId])
  @@index([tenantId, status])
  @@index([tenantId, regulator, licenseType])
  @@map("broker_licenses")
}

/// Status of a claim or verification request.
enum ClaimStatus {
  PENDING
  APPROVED
  REJECTED
}

/// Status of an SBT verification request (L2 identity proof).
enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

/// A request from a user to verify their broker account for L2 SBT.
/// Per ADR-0022: the server never receives raw account data. Instead it
/// stores a commitment hash computed client-side and an encrypted evidence
/// IPFS CID that only an admin can decrypt.
model SbtVerificationRequest {
  id               String             @id @default(uuid()) @db.Uuid
  tenantId         String             @db.Uuid
  userId           String             @db.Uuid
  brokerSlug       String
  commitment       String
  evidenceIpfsCid  String
  evidenceMimeType String?
  status           VerificationStatus @default(PENDING)
  adminNote        String?            @db.Text
  createdAt        DateTime           @default(now())
  reviewedAt       DateTime?

  user               User                @relation(fields: [userId], references: [id])
  tenant             Tenant              @relation(fields: [tenantId], references: [id])
  verifiedBrokerLink UserVerifiedBroker?

  @@index([tenantId, status])
  @@index([tenantId, userId])
  @@map("sbt_verification_requests")
}

/// Append-only record of brokers a user has been verified for. Inserted in
/// the same transaction as the verification approval, with a unique
/// (userId, brokerSlug) constraint. Per ADR-0025 (Phase 1) this list is
/// off-chain — Phase 2 batches these rows into the on-chain ReviewerSBT v2
/// broker mapping. Each row's `commitment` mirrors the original verification
/// request and is also emitted as an outbox event with a hash chain
/// pointing to the user's previous broker, giving auditors a way to detect
/// post-hoc admin tampering until the data lands on-chain.
model UserVerifiedBroker {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @db.Uuid
  userId         String   @db.Uuid
  brokerSlug     String
  verificationId String   @unique @db.Uuid
  commitment     String
  approvedAt     DateTime @default(now())

  user         User                   @relation(fields: [userId], references: [id])
  tenant       Tenant                 @relation(fields: [tenantId], references: [id])
  verification SbtVerificationRequest @relation(fields: [verificationId], references: [id])

  @@unique([userId, brokerSlug])
  @@index([tenantId, userId])
  @@index([tenantId, brokerSlug])
  @@map("user_verified_brokers")
}

/// A request from a merchant to claim ownership of a broker profile.
/// Manual KYC: user provides CE ref number and a company authorization letter
/// (uploaded to IPFS). Admin reviews and approves/rejects.
model BrokerClaimRequest {
  id                   String      @id @default(uuid()) @db.Uuid
  tenantId             String      @db.Uuid
  brokerId             String      @db.Uuid
  userId               String      @db.Uuid
  ceRefNumber          String
  companyLetterIpfsCid String
  status               ClaimStatus @default(PENDING)
  adminNote            String?     @db.Text
  createdAt            DateTime    @default(now())
  reviewedAt           DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id])
  broker Broker @relation(fields: [brokerId], references: [id])

  @@index([tenantId, status])
  @@index([tenantId, brokerId])
  @@map("broker_claim_requests")
}

// =============================================================================
// KOL Enums (per ADR-0036)
// =============================================================================

/// Lifecycle status of a KOL profile. Pre-seeded profiles start UNCLAIMED;
/// real users applying go through PENDING → APPROVED/REJECTED. Admin can
/// suspend any KOL at any time. Per ADR-0036 D1 + D9.
enum KolStatus {
  UNCLAIMED // Pre-seeded by admin, not yet claimed by the real person.
  PENDING // User applied; waiting admin review.
  APPROVED // Active KOL; can emit signals.
  REJECTED // Admin rejected the application.
  SUSPENDED // Admin suspended (post-approval); cannot emit new signals.
}

/// Kind of KOL — the first of two orthogonal, filterable category dimensions
/// per ADR-0053 (mirrors the BrokerCategory discriminator of ADR-0045, but
/// split across two axes because KOL type and asset focus are independent).
/// Both terms are registered in docs/04-glossary.md. New values are
/// non-breaking Postgres ADD VALUEs.
enum KolType {
  FINANCIAL_KOL // 財演 — publicly calls buy/sell.
  INDICATOR_VENDOR // 技術指標賣家 — sells self-built trading-signal indicators.
}

/// Asset focus — the second category dimension per ADR-0053. A deliberately
/// COARSE, profile-level descriptor for discovery/filtering, distinct from the
/// fine-grained per-signal `AssetClass` (ADR-0038) used for settlement routing
/// (see ADR-0053 D4). New values (e.g. COMMODITY) can be appended non-breaking.
enum KolFocus {
  EQUITY // 股票
  CRYPTO // 加密
  FOREX // 外匯
}

/// Broad asset class for KOL signals. Per ADR-0036 D5 + ADR-0038: classifies
/// which oracle pipeline handles settlement and doubles as the `Instrument`
/// catalog category (ADR-0038 D2 — the picker surfaces the five user-facing
/// categories EQUITY_HK / EQUITY_US / INDEX / CRYPTO / COMMODITY).
///
/// ORDER IS LOAD-BEARING: the position maps to the on-chain `uint8 assetClass`
/// in KolSignalRegistry and the outbox worker's ASSET_CLASS_MAP. INDEX and
/// COMMODITY are appended LAST (positions 6 and 7) so the existing 0-5 ordering
/// stays stable. The contract validation widens from `<= 5` to `<= 7` in a
/// later session (per ADR-0038 D3). FUTURES / SPOT / FOREX remain valid legacy
/// values but are not surfaced as new picker categories.
enum AssetClass {
  EQUITY_HK
  EQUITY_US
  FUTURES
  SPOT
  FOREX
  CRYPTO
  INDEX
  COMMODITY
}

/// Direction of a KOL signal call. Per ADR-0036 D4.
enum SignalDirection {
  BUY
  SELL
  HOLD
}

/// Terminal state of a settled signal. Per ADR-0036 D6:
///   - HIT_TARGET:     price touched target during horizon (best outcome)
///   - HIT_DIRECTION:  price moved in correct direction but didn't reach target
///   - STOPPED:        price touched stoploss (immediate loss)
///   - EXPIRED:        horizon elapsed, direction wrong, no target/stoploss touch
///   - UNRESOLVED:     no oracle coverage for this symbol
enum SignalOutcome {
  ACTIVE
  HIT_TARGET
  HIT_DIRECTION
  STOPPED
  EXPIRED
  UNRESOLVED
}

/// Lifecycle status of a review as it moves through the submission pipeline.
/// Reviews start PENDING while IPFS pinning + chain tx are in flight, then
/// transition to CONFIRMED once the chain tx receipt is verified. FAILED marks
/// a permanently broken submission (IPFS or chain failure after max retries).
enum ReviewStatus {
  PENDING // Created in DB; IPFS pin + chain tx not yet confirmed.
  CONFIRMED // On-chain tx confirmed; review is immutable.
  FAILED // Pipeline permanently failed (operator intervention needed).
}

/// Three-way sentiment replacing the legacy 1-5 star `rating` column per
/// ADR-0028. The values map to the project's red-line goal of removing
/// paid-promotion-gameable surfaces (rule 00) while preserving an at-a-glance
/// trust signal that pairs with `verifiedComplaintCount` (per ADR-0029).
///
/// Rendered as `讚 / 普通 / 不好` in zh-Hant per the 2026-05-25 meeting C1
/// resolution; the API uses these enum names verbatim and the UI handles the
/// localisation.
enum Sentiment {
  POSITIVE
  NEUTRAL
  NEGATIVE
}

/// Discriminator separating subjective opinion (`REVIEW`) from alleged
/// verifiable fact (`COMPLAINT`) per ADR-0029. Both kinds share the same
/// `Review` table and the same IPFS pin + on-chain anchor pipeline (per
/// ADR-0019); only the surface-area UX and the verification path differ.
///
/// `REVIEW`     — sentiment-only, no platform verification needed; reader
///                trust comes from the author's SBT tier + verified-broker
///                badge (per ADR-0025).
/// `COMPLAINT`  — alleges a fact (e.g. "platform was unreachable for 2h on
///                2026-04-01"); REQUIRES `evidenceIpfsCid` at submit time
///                (enforced in zod, not at the DB level since reviews don't
///                need it); reader trust comes from `verifiedAt != null`
///                being set by an admin (Phase 1) or by jury vote (Phase 3).
///
/// Existing pre-M7 rows are auto-stamped `REVIEW` via the `@default(REVIEW)`
/// at column-add time (Postgres 11+ fast-default; no UPDATE in migration
/// per rule 31).
enum ReviewKind {
  REVIEW
  COMPLAINT
}

/// An off-chain mirror of a single review submission. The authoritative copy
/// of the content lives on IPFS (addressed by `ipfsCid`), and its tamper-proof
/// anchor lives on-chain in ReviewRegistry (addressed by `chainReviewId` +
/// `txHash`). This DB row exists for fast query and full-text search; it is
/// NOT the source of truth for immutability — the chain is.
///
/// Per ADR-0019 D1: contentHash = keccak256 of the IPFS JSON; the contract
/// stores (contentHash, ipfsCid) and this table mirrors those values so the
/// API can serve reviews without querying the chain on every page load.
///
/// Per ADR-0019 D5 + project red line: there is NO deleteReview endpoint.
/// Soft-delete (`deletedAt`) is reserved for extraordinary legal compliance
/// (court order) and requires an ADR + admin audit log.
model Review {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @db.Uuid
  userId   String @db.Uuid
  brokerId String @db.Uuid

  /// keccak256(JSON.stringify(ipfsPayload)) — matches on-chain contentHash.
  contentHash   String
  /// IPFS CID where the full review JSON is pinned (via Pinata).
  ipfsCid       String?
  /// On-chain review ID returned by ReviewRegistry.submitReview().
  chainReviewId Int?
  /// Transaction hash of the on-chain submission.
  txHash        String?

  title     String     @db.VarChar(200)
  body      String     @db.Text
  /// @deprecated per ADR-0028 D6. Replaced by `sentiment` (three-way axis).
  /// Kept in schema for two releases so any production tooling that reads
  /// the legacy 1-5 column has a migration window. Scheduled drop:
  ///   - Release N   (this ADR): annotated `@deprecated`, `sentiment` added
  ///   - Release N+1: every submit path writes `sentiment`; backfill verified
  ///   - Release N+2: column dropped via Prisma migration + dedicated ADR
  /// Until the drop ADR is written, do not introduce new code paths that
  /// read `rating`; new code reads `sentiment` and treats `rating` as
  /// historical-data-only.
  rating    Int        @db.SmallInt
  /// Three-way sentiment per ADR-0028. Nullable during the M3 transition
  /// window — legacy rows are backfilled by `db:backfill:sentiment` (M3.2)
  /// and the column becomes required at submit time in M4 (ADR-0028 D4).
  sentiment Sentiment?

  status       ReviewStatus @default(PENDING)
  sourceLocale String?

  // ===========================================================================
  // Complaint discriminator + complaint-only fields per ADR-0029 (M7.1).
  // All complaint-specific columns are nullable so existing review rows
  // are valid without backfill — the `@default(REVIEW)` covers `kind`, and
  // every other column is `?`. Application-layer zod enforces the
  // "complaint requires evidence" constraint at submit time (per D3).
  // ===========================================================================

  /// Discriminator: `REVIEW` (subjective opinion) vs `COMPLAINT` (alleged
  /// verifiable fact). Default `REVIEW` so existing rows are auto-stamped
  /// at column-add time without any UPDATE statement (Postgres fast-default).
  /// Per ADR-0029 D1.
  kind               ReviewKind @default(REVIEW)
  /// IPFS CID of the evidence file (PNG / JPEG / PDF / WebP, max 10MB)
  /// attached to a complaint. Required when `kind = COMPLAINT` (enforced
  /// in API zod schema per ADR-0029 D3); always null when `kind = REVIEW`.
  /// Pipeline reuses the `/verify` flow's Pinata uploader end-to-end —
  /// see `POST /v1/auth/verify-broker/upload` for the cap + MIME allow-list
  /// source of truth.
  evidenceIpfsCid    String?
  /// Set when an admin (Phase 1, M7) or jury (Phase 3, future) verifies a
  /// complaint as substantiated. `null` means either pending verification
  /// or actively rejected (`adminNote` distinguishes); per ADR-0029 D4
  /// rejection is non-destructive — the row stays visible with a "not
  /// verified by platform" label per rule 00.
  verifiedAt         DateTime?
  /// User id of the admin who verified the complaint (Phase 1). Phase 3
  /// will add a sibling `verifiedByJuryProposalId` and make this column
  /// nullable when jury verification is the source — column shape is
  /// already nullable so future ADR can layer on without schema break.
  verifiedByUserId   String?    @db.Uuid
  /// Foreign key for broker public-response rows (per ADR-0029 D6 + ADR-0037
  /// D1). A broker response is itself a `Review` row with `kind = REVIEW`
  /// and this field pointing to the complaint's `id`. One response per
  /// complaint per broker is enforced at the application layer (ADR-0037 D2).
  respondsToReviewId String?    @db.Uuid
  /// Admin-supplied free text. Two distinct roles per current usage:
  ///   1. Reject reason (M7 / ADR-0029 D4): when `kind = COMPLAINT` and an
  ///      admin rejects the verification claim — minimum 5 chars enforced
  ///      in zod (sibling of `SbtVerificationRequest.adminNote` pattern).
  ///   2. Future audit note for any moderation action (rule 00 «不刪、只
  ///      標註» direction; Phase 2.5+ will deepen this).
  /// NEVER a place to log PII (rule 50).
  adminNote          String?    @db.Text

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tenant       Tenant              @relation(fields: [tenantId], references: [id])
  user         User                @relation(fields: [userId], references: [id])
  broker       Broker              @relation(fields: [brokerId], references: [id])
  translations ReviewTranslation[]

  // Self-relation: a broker response row points to the complaint it answers.
  // Per ADR-0037 D1: `responseTo` is the complaint; `responses` is the
  // (typically 0-or-1 element) set of broker responses to this complaint.
  responseTo Review?  @relation("ReviewResponse", fields: [respondsToReviewId], references: [id])
  responses  Review[] @relation("ReviewResponse")

  @@index([respondsToReviewId])
  @@index([tenantId, brokerId, createdAt])
  @@index([tenantId, userId])
  @@index([tenantId, status])
  // Powers the `SentimentDistribution` aggregate on the broker detail page
  // (per ADR-0028 D1 + D7); the (tenantId, brokerId) prefix matches every
  // sentiment-grouped query against a single broker.
  @@index([tenantId, brokerId, sentiment])
  // Powers two M7.6a aggregate queries on the broker detail page:
  //   - `sentimentAggregate` filtered by `kind = REVIEW`
  //   - `verifiedComplaintCount` filtered by `kind = COMPLAINT AND verifiedAt IS NOT NULL`
  // Per ADR-0029 D1 + D5; the (tenantId, brokerId) prefix matches every
  // single-broker query and the trailing `verifiedAt` lets Postgres skip
  // unverified complaints in the count without a separate scan.
  @@index([tenantId, brokerId, kind, verifiedAt])
  @@map("reviews")
}

/// Machine-translated version of a review in a specific locale.
/// Per ADR-0023: translations are additive siblings of the original
/// Review content, stored per locale for instant serving.
model ReviewTranslation {
  id           String   @id @default(uuid()) @db.Uuid
  reviewId     String   @db.Uuid
  locale       String
  title        String   @db.VarChar(200)
  body         String   @db.Text
  translatedAt DateTime @default(now())

  review Review @relation(fields: [reviewId], references: [id])

  @@unique([reviewId, locale])
  @@map("review_translations")
}

// =============================================================================
// KOL Models (per ADR-0036)
// =============================================================================

/// A KOL (Key Opinion Leader / 財演) profile. Pre-seeded profiles (UNCLAIMED)
/// exist before the real person claims them; claimed + approved profiles can
/// emit signals. Per ADR-0036 D1, D9.
///
/// KolSbt is an independent soulbound token parallel to ReviewerSbt (ADR-0036
/// D3). The `kolSbtTokenId` / `kolSbtMintTxHash` columns mirror the pattern
/// established in User.sbtTokenId / sbtMintTxHash.
model Kol {
  id               String    @id @default(uuid()) @db.Uuid
  tenantId         String    @db.Uuid
  userId           String?   @db.Uuid
  slug             String    @unique
  displayName      String
  bio              String?   @db.Text
  avatarUrl        String?
  status           KolStatus @default(UNCLAIMED)
  /// First category dimension (kind of KOL) per ADR-0053. Nullable with NO
  /// default: a KOL has no inherent type, so NULL = "uncategorised / not yet
  /// assigned" (set later by onboarding/admin), avoiding any wrong backfill.
  type             KolType?
  /// Second category dimension (asset focus) per ADR-0053. Nullable for the
  /// same reason as `type`; deliberately coarse and distinct from the
  /// per-signal `AssetClass` (ADR-0053 D4).
  focus            KolFocus?
  /// JSON: { youtube?: string, instagram?: string, twitter?: string }
  socialLinks      Json?
  /// JSON array: [{ type: "CFA"|"SFC_TYPE_4"|..., verified: boolean, verifiedAt?: string }]
  credentials      Json?
  iamSmartVerified Boolean   @default(false)
  kolSbtTokenId    Int?
  kolSbtMintTxHash String?
  /// Admin-supplied free text. Primary role today: rejection reason when an
  /// admin transitions a PENDING application to REJECTED (min 5 / max 500
  /// chars enforced at the presentation layer via zod, sibling of
  /// `SbtVerificationRequest.adminNote` + `Review.adminNote` patterns).
  /// Per rule 00 "reject != delete" — REJECTED rows stay visible on the
  /// applicant's `/become-a-kol` and `/kol/onboarding` pages alongside this
  /// note so the user can understand why and resubmit. Per rule 50 — NEVER
  /// a place to log PII; admin moderators must keep notes generic.
  adminNote        String?   @db.Text

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tenant    Tenant      @relation(fields: [tenantId], references: [id])
  user      User?       @relation(fields: [userId], references: [id])
  signals   Signal[]
  followers KolFollow[]
  notes     KolNote[]

  @@index([tenantId, status])
  @@index([tenantId, userId])
  // Category filter dimensions per ADR-0053 D5. The two axes are filtered
  // independently, so two composite (tenantId, <dim>) indexes rather than one
  // combined index (which would not cover focus-only queries).
  @@index([tenantId, type])
  @@index([tenantId, focus])
  @@map("kols")
}

/// A single signal (call) emitted by a KOL. Immutable once on-chain per
/// project red line (no deletion, no modification). Per ADR-0036 D4-D7.
///
/// Settlement fields (settledAt, settlePrice, periodHigh, periodLow) are
/// populated by the Settle Worker (M9.2) when the horizon expires and oracle
/// data is available. Signals without oracle coverage reach UNRESOLVED.
model Signal {
  id            String          @id @default(uuid()) @db.Uuid
  tenantId      String          @db.Uuid
  kolId         String          @db.Uuid
  assetClass    AssetClass
  symbol        String
  /// Optional FK to the curated Instrument catalog (ADR-0038 D6). Set when the
  /// KOL picks a catalog instrument; NULL when they type a free-text symbol.
  /// `symbol` is always populated regardless (normalized canonical code).
  instrumentId  String?         @db.Uuid
  direction     SignalDirection
  entryPrice    Decimal         @db.Decimal(20, 8)
  targetPrice   Decimal         @db.Decimal(20, 8)
  stoplossPrice Decimal?        @db.Decimal(20, 8)
  horizon       Int             @db.SmallInt
  note          String?         @db.VarChar(500)
  outcome       SignalOutcome   @default(ACTIVE)
  settledAt     DateTime?
  settlePrice   Decimal?        @db.Decimal(20, 8)
  periodHigh    Decimal?        @db.Decimal(20, 8)
  periodLow     Decimal?        @db.Decimal(20, 8)

  contentHash   String
  ipfsCid       String?
  chainSignalId Int?
  chainTxHash   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant     Tenant      @relation(fields: [tenantId], references: [id])
  kol        Kol         @relation(fields: [kolId], references: [id])
  instrument Instrument? @relation(fields: [instrumentId], references: [id])
  notes      KolNote[]

  @@index([tenantId, kolId, createdAt])
  @@index([tenantId, outcome])
  @@index([tenantId, symbol])
  @@index([tenantId, assetClass])
  @@index([instrumentId])
  @@map("signals")
}

/// User-KOL follow relationship. Foundation for future paid subscription
/// (Phase 5+ per ADR-0036 D8). Per ADR-0036 D8.
model KolFollow {
  id     String @id @default(uuid()) @db.Uuid
  userId String @db.Uuid
  kolId  String @db.Uuid

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  kol  Kol  @relation(fields: [kolId], references: [id])

  @@unique([userId, kolId])
  @@index([kolId])
  @@map("kol_follows")
}

/// Curated catalog of tradable instruments backing the signal target picker
/// (per ADR-0038). GLOBAL REFERENCE DATA — intentionally has NO `tenantId`
/// (documented rule 31 exception: a market instrument is identical across
/// tenants, like a currency or country lookup). Populated by a periodic sync
/// script (Session 3) from HKEX / SEC / CoinGecko + curated index/commodity
/// JSON; never hard-deleted — use `isActive` to retire a row (rule 31).
///
/// Multilingual names use the parallel-columns pattern (cursor rule 51 §A):
/// `localizedInstrumentName(instrument, locale)` in `@opentrade/shared` picks
/// the right column with `symbol` as the guaranteed non-empty fallback. US
/// equities and crypto usually have no Chinese name (`nameZh` null → English);
/// `nameZhHans` is OpenCC-derived during sync (best-effort, nullable).
model Instrument {
  id          String     @id @default(uuid()) @db.Uuid
  /// Reuses AssetClass as the category (ADR-0038 D2). The picker surfaces
  /// EQUITY_HK / EQUITY_US / INDEX / CRYPTO / COMMODITY.
  category    AssetClass
  /// Normalized canonical code, uppercase (e.g. "00005", "AAPL", "BTC", "HSI").
  symbol      String
  /// What the UI shows as the code (often equals `symbol`, e.g. "00005").
  displayCode String
  /// English name. Nullable for parity with the helper fallback chain.
  nameEn      String?
  /// Traditional Chinese name. Null for instruments with no Chinese name.
  nameZh      String?
  /// Simplified Chinese name (OpenCC-derived during sync). Best-effort, nullable.
  nameZhHans  String?
  /// Listing venue, e.g. "HKEX" / "NASDAQ" / "NYSE". Nullable for crypto/index.
  exchange    String?
  /// Provenance: "HKEX" | "SEC" | "COINGECKO" | "CURATED".
  source      String
  /// Soft retirement flag — never hard-delete reference rows (rule 31).
  isActive    Boolean    @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  signals Signal[]

  @@unique([category, symbol])
  @@index([category, isActive])
  @@index([category, displayCode])
  @@map("instruments")
}

/// A rich-text analyst note authored by a KOL (per ADR-0039). Immutable once
/// published — like Signal, there is NO `deletedAt` (no edit, no delete:
/// project red line + the on-chain anchor in KolNoteRegistry). Tenant-scoped
/// because it is user-generated content (rule 31).
///
/// `bodyJson` holds a portable ProseMirror/TipTap document; embedded images
/// are stored on IPFS and referenced by CID (tracked in `imageCids`), never
/// base64-inlined (ADR-0039 D3). `contentHash` + `ipfsCid` mirror the signal
/// anchor pattern; `chainNoteId` / `chainTxHash` are filled by the outbox
/// worker after KolNoteRegistry.emitNote (Session 4).
model KolNote {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @db.Uuid
  kolId          String   @db.Uuid
  title          String   @db.VarChar(200)
  /// ProseMirror/TipTap document JSON (ADR-0039 D3).
  bodyJson       Json
  /// IPFS CIDs of images embedded in `bodyJson`.
  imageCids      String[]
  /// DB FK to the linked Signal; NULL = standalone note (ADR-0039 D2).
  linkedSignalId String?  @db.Uuid
  contentHash    String
  ipfsCid        String?
  chainNoteId    Int?
  chainTxHash    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant       Tenant  @relation(fields: [tenantId], references: [id])
  kol          Kol     @relation(fields: [kolId], references: [id])
  linkedSignal Signal? @relation(fields: [linkedSignalId], references: [id])

  @@index([tenantId, kolId, createdAt])
  @@index([tenantId, linkedSignalId])
  @@map("kol_notes")
}

/// Transactional outbox for cross-domain domain events (per ADR-0006 outbox
/// pattern). Use cases write business rows + an OutboxEvent in the same DB
/// transaction; a background worker (added in Phase 1) reads pending rows
/// and republishes them to SQS. This guarantees we never "commit the write
/// but lose the event" — the two are atomic at the database level.
///
/// Lifecycle:
///   - `processedAt = null`           → pending; worker will pick it up.
///   - `processedAt != null`          → delivered to downstream.
///   - `attempts` / `lastError`       → retry diagnostics for the worker.
///
/// Retention: per rule 31, processed rows older than 7 days MAY be hard
/// deleted by a cron job (this is the one exception to "never DELETE" rule).
///
/// Field shape:
///   - `aggregateType` — namespaced string identifying the producing
///                       aggregate (e.g. `"review"`, `"kol_signal"`).
///   - `aggregateId`   — UUID of that aggregate, stored as string to keep
///                       this table aggregate-agnostic (no FK).
///   - `eventType`     — dotted event name (e.g. `"review.submitted"`,
///                       `"kol_signal.created"`); the worker uses this to
///                       route to the correct SQS topic / subscriber.
///   - `payload`       — JSON serialisable payload; must NOT contain PII
///                       (per rule 50). Use IDs and hashes, not raw values.
model OutboxEvent {
  id            String    @id @default(uuid()) @db.Uuid
  tenantId      String    @db.Uuid
  aggregateType String
  aggregateId   String    @db.Uuid
  eventType     String
  payload       Json
  attempts      Int       @default(0)
  lastError     String?   @db.Text
  createdAt     DateTime  @default(now())
  processedAt   DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id])

  // Worker query: "fetch oldest unprocessed events". The partial-index shape
  // (processedAt first, createdAt second) lets Postgres skip processed rows
  // efficiently even before the 7-day GC kicks in.
  @@index([processedAt, createdAt])
  // Tenant-scoped pending lookup; mirrors every other table's tenant index.
  @@index([tenantId, processedAt])
  // Forensic lookup: "what events did aggregate X emit?" — used by admin
  // tooling and by reprocessing scripts after a downstream outage.
  @@index([tenantId, aggregateType, aggregateId])
  @@map("outbox_events")
}

// ---------------------------------------------------------------------------
// Notifications (per ADR-0036 D8 — free follow + push notification)
//
// In-app notifications delivered to users when events of interest occur
// (e.g. a followed KOL emits a new signal). Phase 2 uses client-side polling
// (GET /v1/notifications); Phase 5+ may add WebSocket or push.
// ---------------------------------------------------------------------------

enum NotificationType {
  KOL_NEW_SIGNAL
  KOL_SIGNAL_SETTLED
  SYSTEM
}

model Notification {
  id        String           @id @default(uuid()) @db.Uuid
  tenantId  String           @db.Uuid
  userId    String           @db.Uuid
  type      NotificationType
  title     String           @db.VarChar(200)
  body      String?          @db.Text
  metadata  Json?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@index([userId, readAt, createdAt])
  @@index([tenantId, userId])
  @@map("notifications")
}

// ---------------------------------------------------------------------------
// Price Recorder (per ADR-0036 D7)
//
// Off-chain hourly OHLC price data used by the Settle Worker (M9.2) to
// determine signal outcomes. Sources: Chainlink (crypto) + Yahoo Finance
// (traditional finance). Cron-polled every hour.
// ---------------------------------------------------------------------------

enum PriceSource {
  CHAINLINK
  YAHOO_FINANCE
  MANUAL
}

model PriceRecord {
  id        String      @id @default(uuid()) @db.Uuid
  symbol    String      @db.VarChar(30)
  source    PriceSource
  open      Decimal     @db.Decimal(20, 8)
  high      Decimal     @db.Decimal(20, 8)
  low       Decimal     @db.Decimal(20, 8)
  close     Decimal     @db.Decimal(20, 8)
  timestamp DateTime
  createdAt DateTime    @default(now())

  @@unique([symbol, source, timestamp])
  @@index([symbol, timestamp])
  @@map("price_records")
}

// ---------------------------------------------------------------------------
// Content Moderation (per ADR-0034)
//
// Layer 1 of content moderation: a content-NEUTRAL, pre-publication gate that
// blocks prohibited content (profanity / personal attacks / off-platform
// solicitation / illegal) BEFORE a review is anchored on-chain (the only safe
// point given on-chain irreversibility, ADR-0019). It MUST NOT be used to
// suppress negative opinion — that is a rule 00 / rule 52 red line.
//
// The wordlist is admin-editable from the console; every mutation is recorded
// in `ModerationTermAudit` (append-only) so the lever is attributable and
// non-abusable. The pure matching engine lives in `@opentrade/shared`; the API
// loads enabled terms (cached) and is the sole authority. The web client runs
// the same engine against a bundled BASELINE list for advisory UX only.
// ---------------------------------------------------------------------------

/// Category of a blocked term. Content-NEUTRAL by construction: there is
/// deliberately no "negative sentiment" category — criticism is always allowed.
enum ModerationCategory {
  PROFANITY // 髒話 / 粗口 (zh/en + Cantonese)
  ATTACK // 人身攻擊 / hate speech directed at a person
  CONTACT // off-platform solicitation / ads (URLs, TG/WhatsApp handles, phone)
  ILLEGAL // threats, incitement to crime, etc.
  PII // a third party's private identifiers exposed as content (e.g. HKID); ADR-0044
}

/// A single blocked term or pattern. Tenant-scoped (rule 31). Soft-deletable
/// via `deletedAt`; `enabled` toggles enforcement without losing history.
/// `term` itself is NOT PII; do NOT store matched user text here.
model ModerationTerm {
  id              String             @id @default(uuid()) @db.Uuid
  tenantId        String             @db.Uuid
  category        ModerationCategory
  /// Literal substring (normalised) when `isRegex = false`, or a JS regex
  /// source string when `isRegex = true`.
  term            String
  isRegex         Boolean            @default(false)
  enabled         Boolean            @default(true)
  /// Optional operator note (e.g. why this term was added). Not user content.
  note            String?            @db.Text
  /// User id of the admin who created the term (nullable for seeded baseline).
  createdByUserId String?            @db.Uuid
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  deletedAt       DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id])

  // Runtime hot path: load enabled terms for a tenant (optionally by category).
  @@index([tenantId, enabled, category])
  @@map("moderation_terms")
}

/// Append-only audit trail for every change to a `ModerationTerm`. Written in
/// the SAME transaction as the change (ADR-0034 D3). NEVER deleted — this is
/// what makes the moderation lever transparent and non-abusable. `beforeJson`
/// / `afterJson` snapshot the term row only (no user content, no PII).
model ModerationTermAudit {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @db.Uuid
  termId      String   @db.Uuid
  /// One of: CREATE | UPDATE | ENABLE | DISABLE | DELETE.
  action      String
  beforeJson  Json?
  afterJson   Json?
  /// User id of the admin who performed the action (nullable for seed/system).
  actorUserId String?  @db.Uuid
  reason      String?  @db.Text
  createdAt   DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, termId, createdAt])
  @@map("moderation_term_audits")
}
