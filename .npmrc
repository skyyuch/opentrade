# pnpm + npm shared config
# https://pnpm.io/npmrc

# Strict version checking — refuse install if pnpm/Node version mismatch
engine-strict=true

# Workspace behavior
link-workspace-packages=true
prefer-workspace-packages=true
shared-workspace-lockfile=true
save-workspace-protocol=rolling

# Auto-install peers (modern default)
auto-install-peers=true

# Strict peer deps — surface mismatches early
strict-peer-dependencies=false

# Hoisting — limit to known safe types (per pnpm best practices)
public-hoist-pattern[]=*types*
public-hoist-pattern[]=*eslint*
public-hoist-pattern[]=*prettier*

# Side effects cache for faster re-installs
side-effects-cache=true

# Use Node's resolution for PnP-incompatible packages
node-linker=isolated

# Safety: refuse install with lockfile out of date in CI
frozen-lockfile=false
