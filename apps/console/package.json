{
  "name": "@opentrade/console",
  "version": "0.0.0",
  "private": true,
  "description": "OpenTrade B2B back office for brokers, KOLs, and platform admins. Desktop-first, KYC-gated, dark by default.",
  "type": "module",
  "scripts": {
    "dev": "dotenv -e ../../.env -- next dev --port 3001",
    "build": "dotenv -e ../../.env -- next build",
    "start": "dotenv -e ../../.env -- next start --port 3001",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "echo 'no tests yet' && exit 0",
    "test:unit": "echo 'no tests yet' && exit 0",
    "clean": "rm -rf .turbo .next out node_modules/.cache"
  },
  "dependencies": {
    "@opentrade/config": "workspace:*",
    "@opentrade/shared": "workspace:*",
    "@opentrade/ui": "workspace:*",
    "lucide-react": "^0.469.0",
    "next": "~14.2.35",
    "next-intl": "^4.12.0",
    "next-themes": "^0.4.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.20",
    "dotenv-cli": "^11.0.0",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2"
  }
}
