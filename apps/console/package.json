{
  "name": "@opentrade/console",
  "version": "0.0.0",
  "private": true,
  "description": "OpenTrade B2B back office for brokers, KOLs, and platform admins. Desktop-first, KYC-gated, dark by default.",
  "type": "module",
  "scripts": {
    "dev": "dotenv -e ../../.env -- next dev --port 3001",
    "build": "dotenv -e ../../.env -- next build",
    "start": "dotenv -e ../../.env -- next start --port 3001",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "test:ci": "vitest run --coverage",
    "clean": "rm -rf .turbo .next out node_modules/.cache"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@opentrade/config": "workspace:*",
    "@opentrade/shared": "workspace:*",
    "@opentrade/ui": "workspace:*",
    "@privy-io/react-auth": "^3.27.0",
    "@privy-io/wagmi": "^4.0.8",
    "@tanstack/react-query": "^5.100.11",
    "lucide-react": "^0.469.0",
    "next": "~16.2.7",
    "next-intl": "^4.13.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.77.0",
    "viem": "^2.50.4",
    "wagmi": "^3.6.16",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.10.5",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.8",
    "autoprefixer": "^10.4.20",
    "dotenv-cli": "^11.0.0",
    "jsdom": "^26.1.0",
    "postcss": "^8.5.1",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.5",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.8"
  }
}
