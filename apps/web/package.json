{
  "name": "@opentrade/web",
  "version": "0.0.0",
  "private": true,
  "description": "OpenTrade public-facing app for retail investors. Mobile-first, SEO-friendly, three-language UI.",
  "type": "module",
  "scripts": {
    "dev": "dotenv -e ../../.env -- next dev --port 3000",
    "build": "dotenv -e ../../.env -- next build",
    "start": "dotenv -e ../../.env -- next start --port 3000",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "test:ci": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "clean": "rm -rf .turbo .next out node_modules/.cache"
  },
  "dependencies": {
    "@farcaster/mini-app-solana": "^2.0.0",
    "@metamask/connect-evm": "^1.3.1",
    "@opentrade/config": "workspace:*",
    "@opentrade/shared": "workspace:*",
    "@opentrade/ui": "workspace:*",
    "@privy-io/react-auth": "^3.27.0",
    "@privy-io/wagmi": "^4.0.8",
    "@tanstack/react-query": "^5.100.11",
    "@tiptap/extension-image": "^3.24.0",
    "@tiptap/react": "^3.24.0",
    "@tiptap/starter-kit": "^3.24.0",
    "lucide-react": "^0.469.0",
    "next": "~16.2.7",
    "next-intl": "^4.12.0",
    "next-themes": "^0.4.6",
    "permissionless": "^0.3.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "viem": "^2.50.4",
    "wagmi": "^3.6.16",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.1",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.10.5",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^3.2.4",
    "autoprefixer": "^10.4.20",
    "dotenv-cli": "^11.0.0",
    "jsdom": "^26.1.0",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^3.2.4"
  }
}
