{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "preserve",
    "noEmit": true,
    "incremental": true,
    "tsBuildInfoFile": "./node_modules/.cache/.tsbuildinfo",
    "allowJs": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "next.config.mjs",
    "tailwind.config.ts",
    "postcss.config.mjs",
    "src/**/*.ts",
    "src/**/*.tsx",
    ".next/types/**/*.ts",
    "vitest.config.ts",
    "vitest.setup.ts",
    "playwright.config.ts",
    "e2e/**/*.ts",
    ".next-e2e/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".next",
    ".next-e2e/cache",
    ".next-e2e/server",
    ".next-e2e/static",
    "dist",
    "out",
    "playwright-report",
    "test-results"
  ]
}
