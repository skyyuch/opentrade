{
  "name": "@opentrade/api",
  "version": "0.0.0",
  "private": true,
  "description": "OpenTrade backend API. Hono on Node.js with DDD + Modular Monolith architecture.",
  "type": "module",
  "main": "./src/main.ts",
  "scripts": {
    "build": "tsup",
    "dev": "dotenv -e ../../.env -- tsx watch src/main.ts",
    "dev:outbox": "dotenv -e ../../.env -- tsx src/tasks/outbox-worker.ts",
    "start": "node dist/main.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "test:ci": "vitest run --coverage",
    "clean": "rm -rf .turbo dist node_modules/.cache"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1061.0",
    "@hono/node-server": "^2.0.4",
    "@hono/zod-validator": "^0.8.0",
    "@opentrade/config": "workspace:*",
    "@opentrade/db": "workspace:*",
    "@opentrade/shared": "workspace:*",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@privy-io/node": "^0.18.0",
    "bcryptjs": "^3.0.3",
    "hono": "^4.12.23",
    "jose": "^6.2.3",
    "pg": "^8.21.0",
    "pinata": "^2.5.6",
    "pino": "^10.3.1",
    "viem": "^2.50.4",
    "yahoo-finance2": "^3.14.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.8",
    "dotenv-cli": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "tsup": "^8.5.1",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vite": "^7.3.5",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.8",
    "vitest-mock-extended": "^3.1.1"
  }
}
