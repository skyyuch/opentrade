{
  "name": "@opentrade/api",
  "version": "0.0.0",
  "private": true,
  "description": "OpenTrade backend API. Hono on Node.js with DDD + Modular Monolith architecture.",
  "type": "module",
  "main": "./src/main.ts",
  "scripts": {
    "build": "tsup",
    "dev": "dotenv -e ../../.env -- tsx watch src/main.ts",
    "start": "node dist/main.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "echo 'no tests yet' && exit 0",
    "test:unit": "echo 'no tests yet' && exit 0",
    "clean": "rm -rf .turbo dist node_modules/.cache"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.2",
    "@hono/zod-validator": "^0.8.0",
    "@opentrade/config": "workspace:*",
    "@opentrade/db": "workspace:*",
    "@opentrade/shared": "workspace:*",
    "@prisma/client": "^6.19.3",
    "hono": "^4.12.19",
    "pino": "^10.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "tsup": "^8.5.1",
    "tsx": "^4.22.1",
    "typescript": "^5.7.2"
  }
}
