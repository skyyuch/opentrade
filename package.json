{
  "name": "opentrade",
  "version": "0.0.0",
  "private": true,
  "description": "OpenTrade — Web3 decentralized review platform for Hong Kong financial services. See AGENTS.md before contributing.",
  "license": "UNLICENSED",
  "homepage": "https://github.com/skyyuch/opentrade",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/skyyuch/opentrade.git"
  },
  "engines": {
    "node": ">=22.11.0",
    "pnpm": ">=9.15.0"
  },
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint -- --fix",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:unit": "turbo run test:unit",
    "test:watch": "turbo run test:watch",
    "test:ci": "turbo run test:ci",
    "clean": "turbo run clean && rm -rf node_modules .turbo",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,mjs,cjs,json,md,yaml,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,mjs,cjs,json,md,yaml,yml}\"",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.5",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-import-resolver-typescript": "^3.7.0",
    "eslint-plugin-import-x": "^4.6.1",
    "globals": "^15.14.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.3.0",
    "prettier": "^3.4.2",
    "solhint": "^6.2.1",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.1"
  },
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {}
    }
  }
}
